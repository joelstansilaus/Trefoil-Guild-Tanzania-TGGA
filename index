<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Trefoil Guild Tanzania | TGGA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    :root{
      --primary:#1547a8;
      --accent:#fbd80b;
      --text:#172033;
      --muted:#5f6b85;
      --light:#f5f8ff;
      --white:#ffffff;
      --border:#dbe5ff;
      --shadow:0 10px 30px rgba(21,71,168,.10);
      --shadow-md:0 16px 48px rgba(21,71,168,.15);
      --radius:20px;
      --max:1200px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:'Nunito',Arial,sans-serif;
      color:var(--text);
      background:var(--white);
      line-height:1.65;
    }

    a{text-decoration:none;color:inherit}
    img{max-width:100%;display:block}

    .container{
      width:min(var(--max),calc(100% - 40px));
      margin:0 auto;
    }

    .section{ padding:84px 0; }

    .eyebrow{
      display:inline-block;
      padding:7px 16px;
      border-radius:999px;
      background:#edf3ff;
      color:var(--primary);
      font-size:13.5px;
      font-weight:800;
      letter-spacing:.4px;
      text-transform:uppercase;
    }

    h1,h2,h3{ margin:0 0 16px; line-height:1.15; font-family:'Nunito',sans-serif; }
    h1{ font-size:clamp(2.2rem,5vw,3.8rem); max-width:680px; font-weight:900; }
    h2{ font-size:clamp(1.75rem,3vw,2.5rem); font-weight:800; }
    h3{ font-weight:700; }

    p{ margin:0 0 16px; color:var(--muted); font-size:1rem; }

    .btns{ display:flex; gap:14px; flex-wrap:wrap; margin-top:28px; }

    .btn{
      border:none; cursor:pointer; border-radius:999px;
      padding:14px 28px; font-weight:800; font-size:15px;
      transition:.25s ease; display:inline-flex; align-items:center;
      gap:9px; font-family:'Nunito',sans-serif;
    }

    .btn-primary{
      background:var(--accent); color:#13213d;
      box-shadow:0 6px 22px rgba(251,216,11,.45);
    }
    .btn-primary:hover{ transform:translateY(-3px); box-shadow:0 10px 28px rgba(251,216,11,.55); }

    .btn-secondary{ background:transparent; color:var(--white); border:2px solid rgba(255,255,255,.45); }
    .btn-secondary.dark{ color:var(--primary); border-color:var(--primary); }
    .btn-secondary:hover{ background:rgba(255,255,255,.10); }

    /* ══ HEADER ══ */
    header{
      position:sticky; top:0; z-index:1000;
      background:rgba(255,255,255,.97);
      backdrop-filter:blur(14px);
      border-bottom:1px solid rgba(21,71,168,.08);
      box-shadow:0 2px 14px rgba(21,71,168,.06);
    }

    .nav{
      min-height:78px; display:flex;
      align-items:center; justify-content:space-between; gap:20px;
    }

    .brand{
      display:flex; align-items:center; gap:12px;
      font-weight:800; color:var(--primary); text-decoration:none;
    }
    .brand-logo{ width:48px; height:48px; border-radius:12px; overflow:hidden; flex-shrink:0; box-shadow:var(--shadow); }
    .brand-logo img{ width:100%; height:100%; object-fit:cover; }
    .brand-name{ font-size:17px; font-weight:900; color:var(--primary); line-height:1.25; }
    .brand-sub{ font-size:11.5px; color:var(--muted); font-weight:700; letter-spacing:.3px; }

    .nav-links{ display:flex; align-items:center; gap:26px; font-size:15px; font-weight:700; }
    .nav-links a{ color:#2a3550; transition:color .2s; padding:4px 0; border-bottom:2px solid transparent; }
    .nav-links a:hover{ color:var(--primary); border-bottom-color:var(--accent); }
    .nav-links .nav-join{
      background:var(--primary); color:var(--white); padding:9px 22px;
      border-radius:999px; border-bottom:none; box-shadow:0 4px 14px rgba(21,71,168,.3);
    }
    .nav-links .nav-join:hover{ background:#0e3990; transform:translateY(-1px); }

    .menu-toggle{ display:none; background:none; border:none; font-size:28px; color:var(--primary); cursor:pointer; }

    /* ══ HERO ══ */
    .hero{
      position:relative; overflow:hidden;
      background:
        radial-gradient(circle at top right,rgba(251,216,11,.22),transparent 28%),
        radial-gradient(circle at left center,rgba(21,71,168,.10),transparent 32%),
        linear-gradient(135deg,#f8fbff 0%,#eef4ff 100%);
    }

    .hero-wrap{
      min-height:calc(100vh - 78px);
      display:grid; grid-template-columns:1.15fr .85fr;
      align-items:center; gap:40px; padding:56px 0 30px;
    }

    .hero-card{
      background:var(--white); border:1px solid var(--border);
      border-radius:28px; box-shadow:var(--shadow-md);
      padding:20px; position:relative; overflow:hidden;
    }

    /* ══ REDESIGNED HERO ILLUSTRATION ══ */
    .hero-visual{
      min-height:500px;
      background:linear-gradient(160deg,#e8f2ff 0%,#d6e8ff 40%,#c8e0ff 100%);
      border-radius:22px;
      position:relative;
      overflow:hidden;
    }

    /* Sky gradient */
    .sky{
      position:absolute; inset:0;
      background:linear-gradient(180deg,#b8d8f8 0%,#d6eaff 45%,#e8f4e8 45%,#c8e8b0 100%);
    }

    /* Sun */
    .sun{
      position:absolute; top:32px; right:40px;
      width:64px; height:64px; border-radius:50%;
      background:radial-gradient(circle,#fff176 30%,#ffe45c 70%,#ffc107 100%);
      box-shadow:0 0 0 8px rgba(255,228,92,.25), 0 0 0 18px rgba(255,228,92,.12);
    }

    /* Ground */
    .ground{
      position:absolute; bottom:0; left:0; right:0; height:52%;
      background:linear-gradient(180deg,#7dc86a 0%,#5aad44 100%);
      border-radius:60% 60% 0 0 / 18px 18px 0 0;
    }

    /* Path */
    .path{
      position:absolute; bottom:0; left:50%; transform:translateX(-50%);
      width:60px; height:60%;
      background:linear-gradient(180deg,#d4a96a,#c49050);
      clip-path:polygon(20% 0%,80% 0%,100% 100%,0% 100%);
    }

    /* Trees — left group */
    .tree-grp{ position:absolute; bottom:46%; display:flex; align-items:flex-end; gap:6px; }
    .tree-grp.left{ left:24px; }
    .tree-grp.right{ right:20px; }

    .t{ display:flex; flex-direction:column; align-items:center; }
    .t-trunk{ background:#8B5E3C; border-radius:4px; }
    .t-crown{ border-radius:50% 50% 45% 45%; background:#4CAF50; }

    .t.tall .t-trunk{ width:10px; height:40px; }
    .t.tall .t-crown{ width:52px; height:58px; margin-bottom:-6px; background:#388E3C; box-shadow:inset -6px -8px 0 rgba(0,0,0,.12); }

    .t.med .t-trunk{ width:8px; height:28px; }
    .t.med .t-crown{ width:38px; height:44px; margin-bottom:-5px; background:#43A047; box-shadow:inset -4px -6px 0 rgba(0,0,0,.10); }

    .t.sm .t-trunk{ width:6px; height:18px; }
    .t.sm .t-crown{ width:26px; height:30px; margin-bottom:-4px; background:#66BB6A; }

    /* Hut */
    .hut{
      position:absolute; bottom:46%; left:50%; transform:translateX(-90px);
      width:72px;
    }
    .hut-roof{
      width:0; height:0;
      border-left:44px solid transparent;
      border-right:44px solid transparent;
      border-bottom:36px solid #c0392b;
      margin:0 auto;
    }
    .hut-body{
      width:72px; height:40px;
      background:#e8d5b0;
      border-radius:4px 4px 0 0;
      position:relative;
    }
    .hut-door{
      position:absolute; bottom:0; left:50%; transform:translateX(-50%);
      width:18px; height:24px;
      background:#7b5534;
      border-radius:9px 9px 0 0;
    }
    .hut-window{
      position:absolute; top:8px; right:10px;
      width:12px; height:12px;
      background:#a8d4f0;
      border-radius:2px;
      border:2px solid #7b5534;
    }

    /* Three women figures */
    .women{ position:absolute; bottom:44%; left:50%; transform:translateX(-50%); display:flex; gap:14px; align-items:flex-end; }

    .woman{ display:flex; flex-direction:column; align-items:center; }

    /* Head */
    .w-head{
      width:22px; height:22px; border-radius:50%;
      position:relative; z-index:3;
    }
    /* Hair wrap / headscarf */
    .w-wrap{
      width:26px; height:13px; border-radius:13px 13px 0 0;
      position:absolute; top:-2px; left:-2px; z-index:4;
    }
    /* Body dress */
    .w-body{
      width:26px; height:34px;
      border-radius:4px 4px 12px 12px;
      margin-top:-2px; position:relative; z-index:2;
    }
    /* Skirt flare */
    .w-skirt{
      width:36px; height:12px;
      border-radius:0 0 14px 14px;
      margin-top:-4px; z-index:1;
    }
    /* Arms */
    .w-arms{ position:relative; display:flex; justify-content:space-between; width:38px; margin-top:-30px; z-index:5; }
    .w-arm{ width:8px; height:22px; border-radius:4px; }
    .w-arm.l{ transform:rotate(20deg); transform-origin:top center; }
    .w-arm.r{ transform:rotate(-20deg); transform-origin:top center; }

    /* Woman 1 — blue uniform */
    .w1 .w-head{ background:#8B6344; }
    .w1 .w-wrap{ background:#1a47a0; }
    .w1 .w-body{ background:#1547a8; }
    .w1 .w-skirt{ background:#1238a0; }
    .w1 .w-arm{ background:#8B6344; }

    /* Woman 2 — centre, slightly taller, yellow scarf */
    .w2 .w-head{ background:#6B4423; }
    .w2 .w-wrap{ background:#fbd80b; }
    .w2 .w-body{ background:#1547a8; }
    .w2 .w-skirt{ background:#0e3990; }
    .w2 .w-arm{ background:#6B4423; }
    .w2{ transform:scale(1.08); }

    /* Woman 3 — green accents */
    .w3 .w-head{ background:#9C7248; }
    .w3 .w-wrap{ background:#2e7d32; }
    .w3 .w-body{ background:#1547a8; }
    .w3 .w-skirt{ background:#1238a0; }
    .w3 .w-arm{ background:#9C7248; }

    /* Globe held by centre woman */
    .globe{
      width:32px; height:32px; border-radius:50%;
      background:radial-gradient(circle at 38% 35%,#7dd3ff 0%,#56b8ec 65%,#3b9ed6 100%);
      box-shadow:inset 6px -6px 0 rgba(255,255,255,.15),0 3px 10px rgba(0,0,0,.14);
      position:absolute; bottom:44px; left:50%; transform:translateX(-50%);
      z-index:6;
    }
    .globe::before{
      content:"";
      position:absolute;
      background:#57a95c;
      border-radius:45% 55% 60% 40%;
      width:14px; height:8px;
      left:6px; top:9px;
      transform:rotate(14deg);
    }
    .globe::after{
      content:"";
      position:absolute;
      background:#57a95c;
      border-radius:45% 55% 60% 40%;
      width:11px; height:8px;
      right:5px; bottom:6px;
      transform:rotate(-18deg);
    }

    /* Floating badges */
    .floating-badge{
      position:absolute;
      background:var(--white);
      border:1px solid var(--border);
      border-radius:14px;
      box-shadow:var(--shadow);
      padding:10px 14px;
      font-size:13px;
      font-weight:800;
      color:var(--primary);
      white-space:nowrap;
    }
    .badge-1{ top:24px; left:20px; }
    .badge-2{ bottom:18px; right:16px; }
    .badge-3{ top:50%; right:14px; transform:translateY(-50%); }

    /* ══ ABOUT ══ */
    .grid-2{ display:grid; grid-template-columns:1fr 1fr; gap:40px; align-items:center; }

    .about-card{
      background:var(--light); border:1px solid var(--border);
      border-radius:var(--radius); padding:36px; box-shadow:var(--shadow);
    }

    .about-visual{
      min-height:360px; border-radius:var(--radius);
      background:linear-gradient(135deg,#edf4ff,#ffffff);
      position:relative; overflow:hidden;
      border:1px solid var(--border); box-shadow:var(--shadow);
    }

    .circle{ position:absolute; border-radius:50%; background:rgba(21,71,168,.08); }
    .circle.one{ width:180px; height:180px; top:28px; left:28px; }
    .circle.two{ width:110px; height:110px; right:36px; top:42px; }
    .circle.three{ width:220px; height:220px; right:-30px; bottom:-20px; }

    .quote-box{
      position:absolute; left:32px; right:32px; bottom:32px;
      background:var(--white); border-radius:18px; padding:24px;
      border:1px solid var(--border); box-shadow:var(--shadow);
    }

    /* ══ ACTIVITIES ══ */
    .cards{ display:grid; grid-template-columns:repeat(4,1fr); gap:24px; margin-top:32px; }

    .card{
      background:var(--white); border:1px solid var(--border);
      border-radius:20px; padding:28px 22px; box-shadow:var(--shadow);
      transition:.25s ease; position:relative; overflow:hidden;
    }
    .card::after{
      content:""; position:absolute; top:0; left:0; right:0; height:3px;
      background:linear-gradient(90deg,var(--primary),var(--accent));
      transform:scaleX(0); transform-origin:left; transition:.3s ease;
    }
    .card:hover{ transform:translateY(-6px); box-shadow:var(--shadow-md); }
    .card:hover::after{ transform:scaleX(1); }

    .icon{
      width:54px; height:54px; border-radius:16px;
      display:grid; place-items:center;
      background:#edf3ff; font-size:26px; margin-bottom:16px;
    }

    /* ══ STATS ══ */
    .stats{
      background:linear-gradient(135deg,var(--primary),#285cc5);
      border-radius:28px; padding:36px;
      box-shadow:var(--shadow-md);
      color:var(--white);
      display:grid; grid-template-columns:repeat(4,1fr); gap:18px;
      margin-top:32px;
    }

    .stat{
      background:rgba(255,255,255,.08);
      border:1px solid rgba(255,255,255,.12);
      padding:28px 20px; border-radius:20px; text-align:center;
      transition:.2s;
    }
    .stat:hover{ background:rgba(255,255,255,.14); }

    .stat-number{
      font-size:2.5rem; font-weight:900;
      color:var(--accent); margin-bottom:8px;
    }
    .stat-label{ font-size:14px; font-weight:600; color:rgba(255,255,255,.85); }

    /* ══ GALLERY — fixed overlap ══ */
    .gallery{ display:grid; grid-template-columns:repeat(3,1fr); gap:24px; margin-top:32px; }

    .gallery-item{
      background:var(--white); border:1px solid var(--border);
      border-radius:20px; overflow:hidden; box-shadow:var(--shadow);
      transition:.25s ease;
    }
    .gallery-item:hover{ transform:translateY(-4px); box-shadow:var(--shadow-md); }

    /* Fixed: art block is self-contained, circles are INSIDE and clipped */
    .gallery-art{
      height:190px;
      background:linear-gradient(145deg,#dce8ff,#e8f2ff);
      position:relative;
      overflow:hidden;   /* clips the circles so they cannot bleed into text */
    }

    /* Decorative accent — bottom edge only, fully inside the art box */
    .gallery-art::before{
      content:"";
      position:absolute;
      border-radius:50%;
      width:130px; height:130px;
      background:rgba(21,71,168,.13);
      bottom:-50px; left:-30px;
    }
    .gallery-art::after{
      content:"";
      position:absolute;
      border-radius:50%;
      width:100px; height:100px;
      background:rgba(251,216,11,.22);
      bottom:-40px; right:-20px;
    }

    /* Icon centred in the art box */
    .gallery-icon{
      position:absolute; top:50%; left:50%; transform:translate(-50%,-60%);
      font-size:48px; z-index:2;
      filter:drop-shadow(0 4px 8px rgba(21,71,168,.18));
    }

    .gallery-label{
      position:absolute; bottom:10px; left:50%; transform:translateX(-50%);
      background:rgba(21,71,168,.85);
      color:#fff; font-size:11px; font-weight:800;
      letter-spacing:.6px; text-transform:uppercase;
      padding:4px 12px; border-radius:999px; white-space:nowrap; z-index:2;
    }

    .gallery-copy{ padding:20px 20px 22px; }
    .gallery-copy h3{ font-size:17px; font-weight:800; color:var(--text); margin-bottom:8px; }
    .gallery-copy p{ font-size:14px; line-height:1.6; margin:0; }

    /* ══ CTA ══ */
    .cta{
      background:
        radial-gradient(circle at top right,rgba(251,216,11,.18),transparent 28%),
        linear-gradient(135deg,var(--primary),#1b56c9);
      color:var(--white); border-radius:30px;
      padding:64px 48px; box-shadow:var(--shadow-md); text-align:center;
    }
    .cta h2{ color:var(--white); }
    .cta p{ color:rgba(255,255,255,.88); max-width:620px; margin:0 auto 12px; font-size:1.05rem; }

    /* ══ TESTIMONIAL — removed "why this layout" side panel ══ */
    .testimonial-section{ padding:80px 0; background:var(--light); }

    .testimonial-inner{
      max-width:820px; margin:0 auto; text-align:center;
    }

    .t-quote-icon{
      font-size:64px; color:var(--primary); opacity:.15;
      line-height:1; margin-bottom:-16px; display:block;
    }

    .testimonial-quote{
      font-size:1.25rem; font-weight:700;
      color:var(--text); line-height:1.75;
      font-style:italic; margin:0 0 24px;
    }

    .testimonial-author{
      display:inline-flex; align-items:center; gap:12px;
      background:var(--white); border:1px solid var(--border);
      border-radius:999px; padding:10px 22px 10px 10px;
      box-shadow:var(--shadow);
    }

    .author-avatar{
      width:40px; height:40px; border-radius:50%;
      background:linear-gradient(135deg,var(--primary),#3972df);
      color:#fff; font-size:18px;
      display:grid; place-items:center;
      flex-shrink:0;
    }

    .author-name{ font-size:14px; font-weight:800; color:var(--text); }
    .author-role{ font-size:12px; color:var(--muted); font-weight:600; }

    .t-dots{ display:flex; justify-content:center; gap:8px; margin-top:28px; }
    .t-dot{
      width:8px; height:8px; border-radius:50%;
      background:rgba(21,71,168,.18); cursor:pointer;
      transition:all .3s;
    }
    .t-dot.active{ background:var(--primary); transform:scale(1.4); }

    /* ══ FOOTER ══ */
    .footer{
      background:#0f2f72; color:var(--white);
      padding:60px 0 28px; margin-top:80px;
    }

    .footer-grid{
      display:grid; grid-template-columns:1.4fr .8fr .8fr;
      gap:32px; margin-bottom:36px;
    }

    .footer-brand-row{ display:flex; align-items:center; gap:12px; margin-bottom:16px; }
    .footer-logo{ width:46px; height:46px; border-radius:12px; overflow:hidden; flex-shrink:0; }
    .footer-logo img{ width:100%; height:100%; object-fit:cover; }
    .footer-brand-name{ font-size:16px; font-weight:900; color:var(--white); line-height:1.25; }
    .footer-brand-sub{ font-size:11.5px; color:rgba(255,255,255,.5); font-weight:600; }

    .footer p{ color:rgba(255,255,255,.75); font-size:14.5px; }
    .footer a{ color:rgba(255,255,255,.75); font-size:14.5px; transition:color .2s; }
    .footer a:hover{ color:var(--accent); }
    .footer h3{ margin-bottom:14px; font-size:17px; font-weight:800; color:var(--white); }

    .footer-links{ display:flex; flex-direction:column; gap:10px; }
    .footer-links a{
      color:rgba(255,255,255,.75); font-size:14.5px;
      transition:color .2s, padding-left .2s;
      display:flex; align-items:center; gap:6px;
    }
    .footer-links a:hover{ color:var(--accent); padding-left:4px; }

    .contact-row{ display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; }
    .contact-row .ci{ font-size:16px; margin-top:2px; flex-shrink:0; }

    .copyright{
      border-top:1px solid rgba(255,255,255,.10);
      padding-top:22px; font-size:13px;
      color:rgba(255,255,255,.45);
      display:flex; align-items:center;
      justify-content:space-between; flex-wrap:wrap; gap:10px;
    }

    /* ══ REVEAL ══ */
    .reveal{ opacity:0; transform:translateY(24px); transition:opacity .7s ease,transform .7s ease; }
    .reveal.visible{ opacity:1; transform:translateY(0); }

    /* ══ RESPONSIVE ══ */
    @media(max-width:1024px){
      .hero-wrap,.grid-2{ grid-template-columns:1fr; }
      .cards{ grid-template-columns:repeat(2,1fr); }
      .gallery{ grid-template-columns:1fr 1fr; }
      .stats{ grid-template-columns:repeat(2,1fr); }
      .hero-wrap{ min-height:auto; padding:40px 0 20px; }
      .footer-grid{ grid-template-columns:1fr 1fr; }
    }

    @media(max-width:760px){
      .section{ padding:56px 0; }
      .container{ width:calc(100% - 24px); }
      .nav{ min-height:72px; }
      .menu-toggle{ display:block; }
      .nav-links{
        position:absolute; top:72px; left:0; right:0;
        background:var(--white);
        border-bottom:1px solid rgba(21,71,168,.08);
        display:none; flex-direction:column;
        align-items:flex-start;
        padding:18px 20px 22px; gap:18px;
        box-shadow:0 8px 24px rgba(21,71,168,.08);
      }
      .nav-links.open{ display:flex; }
      .hero-visual{ min-height:400px; }
      .cards,.gallery,.stats,.footer-grid{ grid-template-columns:1fr; }
      .btns{ gap:12px; }
      .btn{ width:100%; justify-content:center; }
      .floating-badge{ font-size:11.5px; padding:9px 12px; }
      .quote-box{ left:18px; right:18px; bottom:18px; padding:18px; }
      .cta{ padding:40px 20px; }
      .copyright{ flex-direction:column; text-align:center; }
    }
  </style>
</head>
