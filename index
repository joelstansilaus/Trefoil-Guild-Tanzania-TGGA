<script>
  /* Mobile nav */
  const menuToggle = document.getElementById('menuToggle');
  const navLinks   = document.getElementById('navLinks');
  menuToggle.addEventListener('click',()=>navLinks.classList.toggle('open'));
  document.querySelectorAll('.nav-links a').forEach(l=>l.addEventListener('click',()=>navLinks.classList.remove('open')));

  /* Scroll reveal */
  const ro = new IntersectionObserver(entries=>{
    entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('visible'); });
  },{threshold:0.12});
  document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));

  /* Counter */
  const so = new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(!e.isIntersecting)return;
      const el=e.target, target=+el.dataset.target;
      let c=0; const step=Math.max(1,Math.ceil(target/40));
      const t=setInterval(()=>{ c+=step; if(c>=target){el.textContent=target+'+';clearInterval(t);}else el.textContent=c+'+'; },30);
      so.unobserve(el);
    });
  },{threshold:0.6});
  document.querySelectorAll('.stat-number').forEach(s=>so.observe(s));

  /* Testimonials */
  const tData = [
    { text:'Trefoil Guild gives us a meaningful way to continue our Guiding journey, support others, and stay connected to the values we have always carried.', author:'Guild Member, Dar es Salaam' },
    { text:'This is more than a network. It is a space for service, belonging, and mentoring the next generation of women leaders across Tanzania.', author:'Guild Leader, Mwanza' },
    { text:'Being part of the Trefoil Guild reconnected me to my purpose. The fellowship and community spirit here are truly unmatched.', author:'Adult Member, Arusha' }
  ];
  let cur=0;
  const qText=document.getElementById('quoteText');
  const qAuth=document.getElementById('quoteAuthor');
  const dots=document.querySelectorAll('.t-dot');

  function showT(i){
    cur=i;
    qText.style.opacity='0'; qAuth.style.opacity='0';
    setTimeout(()=>{
      qText.textContent=tData[i].text;
      qAuth.textContent=tData[i].author;
      qText.style.opacity='1'; qAuth.style.opacity='1';
    },280);
    dots.forEach((d,j)=>d.classList.toggle('active',j===i));
  }

  qText.style.transition='opacity .28s ease';
  qAuth.style.transition='opacity .28s ease';
  dots.forEach(d=>d.addEventListener('click',()=>showT(+d.dataset.i)));
  setInterval(()=>showT((cur+1)%tData.length),5000);
</script>

